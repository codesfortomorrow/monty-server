generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [ltree]
}

// Enums
enum AdminStatus {
  Active @map("active")

  @@map("admin_status")
}

enum UserStatus {
  Active    @map("active")
  Blocked   @map("blocked")
  Inactive  @map("inactive")
  Suspended @map("suspended")
  BetLock   @map("bet_lock")

  @@map("user_status")
}

enum OtpTransport {
  Email  @map("email")
  Mobile @map("mobile")

  @@map("otp_transport")
}

enum SettingType {
  Binary       @map("binary")
  MultiSelect  @map("multi_select")
  SingleSelect @map("single_select")

  @@map("setting_type")
}

enum BankSelectType {
  Account1 @map("account1")
  Account2 @map("account2")
  Account3 @map("account3")

  @@map("bank_select_type")
}

enum UpiType {
  QR1 @map("QR1")
  QR2 @map("QR2")
  QR3 @map("QR3")

  @@map("upi_type")
}

enum AccountType {
  Savings  @map("savings")
  Current  @map("current")
  Personal @map("personal")

  @@map("account_type")
}

enum SettingContext {
  User   @map("user")
  System @map("system")

  @@map("setting_context")
}

enum WalletType {
  Main  @map("main")
  Bonus @map("bonus")

  @@map("wallet_type")
}

enum DeviceType {
  Desktop @map("desktop")
  Mobile  @map("mobile")
}

enum WalletTransactionType {
  Debit  @map("debit")
  Credit @map("credit")

  @@map("wallet_transaction_type")
}

enum LoginStatus {
  Success @map("success")
  Failed  @map("failed")
}

enum WalletTransactionStatus {
  Pending   @map("pending")
  Confirmed @map("confirmed")
  Failed    @map("failed")
  Approved  @map("approved")
  Rejected  @map("rejected")

  @@map("wallet_transaction_status")
}

enum WalletTransactionContext {
  Deposit            @map("deposit")
  Withdrawal         @map("withdrawal")
  WithdrawalRefund   @map("withdrawal_refund")
  SystemDeposit      @map("system_deposit")
  SystemWithdrawal   @map("system_withdrawal")
  Win                @map("win")
  Won                @map("won")
  Lost               @map("lost")
  Bet                @map("bet")
  BetRefund          @map("bet_refund")
  Rollback           @map("rollback")
  Bonus              @map("bonus")
  CryptoDeposit      @map("crypto_deposit")
  CryptoWithdrawal   @map("crypto_withdrawal")
  CasinoBet          @map("casino_bet")
  CasinoBetRefund    @map("casino_bet_refund")
  CasinoWin          @map("casino_win")
  PointIssue         @map("point_issue")
  PointRemove        @map("point_remove")
  DepositApproval    @map("deposit_approval")
  WithdrawalApproval @map("withdrawal_approval")
  Commission         @map("commission")
  BonusSettlement    @map("bonus_settlement")

  JoiningBonus                @map("joining_bonus")
  ReferralBonus               @map("referral_bonus")
  ReferralLossCommissionBonus @map("referral_loss_commission_bonus")
  LossBackBonus               @map("loss_back_bonus")
  DepositBonus                @map("deposit_bonus")
  BonusCancelled              @map("bonus_cancelled")

  @@map("wallet_transaction_context")
}

enum SportType {
  Cricket     @map("cricket")
  Football    @map("football")
  Tennis      @map("tennis")
  Greyhound   @map("greyhound")
  HorseRacing @map("horse_racing")
  Basketball  @map("basketball")
  Soccer      @map("soccer")
  Other       @map("other")

  @@map("sport_type")
}

enum ProviderType {
  Sports         @map("sports")
  Casino         @map("casino")
  Sms            @map("sms")
  Email          @map("email")
  PaymentGateway @map("payment_gateway")
