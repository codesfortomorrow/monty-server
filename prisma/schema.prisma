// Models
model Admin {
  id             BigInt      @id @default(autoincrement()) @map("id")
  firstname      String      @map("firstname")
  lastname       String      @map("lastname")
  email          String      @unique @map("email")
  profileImage   String?     @map("profile_image")
  status         AdminStatus @default(Active) @map("status")
  roleId         Int         @map("role_id")
  loginUniqueKey String?     @map("login_unique_key")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  meta            AdminMeta?
  role            Role?            @relation("RoleToAdmin", fields: [roleId], references: [id])
  exports         Export[]
  wallets         Wallet[]
  bank            Bank[]
  Crypto          Crypto[]
  upi             Upi[]
  digitalPayments DigitalPayment[]

  @@map("admin")
}

model AdminMeta {
  passwordSalt    String?  @map("password_salt")
  passwordHash    String?  @map("password_hash")
  transactionCode String?  @map("transaction_code")
  adminId         BigInt   @unique @map("admin_id")
  mfaSecret       String?  @map("mfa_secret")
  isMfaEnabled    Boolean? @default(false) @map("is_mfa_enabled")

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("admin_meta")
}

model User {
  id                    BigInt     @id @default(autoincrement()) @map("id")
  firstname             String?    @map("firstname")
  lastname              String?    @map("lastname")
  username              String?    @unique @map("username")
  email                 String?    @unique @map("email")
  dialCode              String?    @map("dial_code")
  mobile                String?    @unique @map("mobile")
  profileImage          String?    @map("profile_image")
  isVerified            Boolean    @default(false) @map("is_verified")
  country               String?    @map("country")
  status                UserStatus @default(Active) @map("status")
  statusChangedBy       BigInt?    @map("status_changed_by")
  partnership           Int        @default(0) @map("partnership")
  parentPartnership     Int        @default(0) @map("parent_partnership")
  commision             Int        @default(0) @map("commision")
  isSelfRegistered      Boolean    @default(false) @map("is_self_registered")
  createdBy             String?    @map("created_by")
  isPartnershipEnabled  Boolean    @default(false) @map("is_partnership_enabled")
  passwordChanged       Boolean?   @default(true) @map("password_changed")
  transactionCodeViewed Boolean?   @default(true) @map("transaction_code_viewed")
  roleId                Int        @map("role_id")
  referralCode          String?    @map("referral_code")
  loginUniqueKey        String?    @map("login_unique_key")
  ChangeStatuasAt       DateTime?  @map("change_status_at")
  deletedAt             DateTime?  @map("deleted_at") @db.Timestamptz
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  role                       Role?                       @relation("RoleToUser", fields: [roleId], references: [id])
  meta                       UserMeta?
  kyc                        Kyc?
  wallets                    Wallet[]
  userBonus                  BonusApplicantStatusType[]
  referralsSent              Referral[]                  @relation("Referrer")
  referralsReceived          Referral[]                  @relation("Referee")
  affiliate                  Affiliate[]
  affiliateReferral          AffiliateReferral[]
  bets                       Bet[]
  casinoTransactions         CasinoTransaction[]
  CasinoRoundHistories       CasinoRoundHistory[]
  recentGames                RecentGame[]
  favoriteGames              FavoriteGame[]
  userSetting                UserSetting[]
  Exposure                   Exposure[]
  Bank                       Bank[]
  Crypto                     Crypto[]
  Upis                       Upi[]
  Export                     Export[]
  DigitalPayment             DigitalPayment[]
  activeBankers              ActiveBanker[]
  paymentConfig              PaymentConfig[]
  stakeSets                  StakeSet?
  sportsPermissions          SportsPermission?
  depositWithdrawRequests    DepositWithdrawRequest[]    @relation("UserRequestRelation")
  depositWithdrawApproved    DepositWithdrawRequest[]    @relation("BankerUserRelation")
  turnoverHistories          TurnoverHistory[]
  bonusAuditLogs             BonusAuditLog[]
  affiliateWeeklyActiveUsers AffiliateWeeklyActiveUser[]
  userWalletstats            UserWalletStat?             @relation(fields: [userWalletStatId], references: [id])
  appliedBonuses             BonusApplicant[]            @relation("UserBonusApplicants")
  approvedBonuses            BonusApplicant[]            @relation("ApprovedBonusApplicants")
  bonusLimitCounters         BonusLimitCounter[]
  userWalletStatId           BigInt?

  @@map("user")
}

model UserMeta {
  id              BigInt                @id @default(autoincrement())
  googleId        String?               @unique @map("google_id")
  passwordSalt    String?               @map("password_salt")
  passwordHash    String?               @map("password_hash")
  transactionCode String?               @map("transaction_code")
  mfaSecret       String?               @map("mfa_secret")
  isMfaEnabled    Boolean?              @default(false) @map("is_mfa_enabled")
  userId          BigInt                @unique @map("user_id")
  casinoToken     String?               @map("casino_token")
  uplineId        String?               @map("upline_id")
  upline          Unsupported("ltree")?

  user User @relation(fields: [userId], references: [id])

  @@map("user_meta")
}

model Otp {
  code             String       @map("code")
  attempt          Int          @default(1) @map("attempt") @db.SmallInt
  lastSentAt       DateTime     @default(now()) @map("last_sent_at") @db.Timestamptz
  retries          Int          @default(0) @map("retries") @db.SmallInt
  transport        OtpTransport @map("transport")
  target           String       @map("target")
  lastCodeVerified Boolean      @default(false) @map("last_code_verified")
  blocked          Boolean      @default(false) @map("blocked")

  @@unique([transport, target])
  @@map("otp")
}

model Setting {
  id               Int            @id @default(autoincrement()) @map("id")
  mappedTo         String         @map("mapped_to")
  text             String         @default("") @map("text")
  description      String         @default("") @map("description")
  type             SettingType    @map("type")
  context          SettingContext @map("context")
  default          Json           @map("default")
  isDefinedOptions Boolean        @map("is_defined_options")
  parentId         Int?           @map("parent_id")

  subSettings   Setting[]       @relation("SubSettings")
  dependsOn     Setting?        @relation("SubSettings", fields: [parentId], references: [id])
  options       SettingOption[]
  userSetting   UserSetting[]
  systemSetting SystemSetting[]

  @@unique([context, mappedTo])
  @@map("setting")
}

model SettingOption {
  id        Int    @id @default(autoincrement()) @map("id")
  text      String @default("") @map("text")
  value     String @map("value")
  settingId Int    @map("setting_id")

  setting Setting @relation(fields: [settingId], references: [id])

  @@unique([settingId, value])
  @@map("setting_option")
}

model UserSetting {
  userId    BigInt @map("user_id")
  settingId Int    @map("setting_id")
  selection Json   @map("selection")

  user    User    @relation(fields: [userId], references: [id])
  setting Setting @relation(fields: [settingId], references: [id])

  @@id([userId, settingId])
  @@map("user_setting")
}

model SystemSetting {
  settingId Int  @id @map("setting_id")
  selection Json @map("selection")

  setting Setting @relation(fields: [settingId], references: [id])

  @@map("system_setting")
}

model Wallet {
  id                    BigInt     @id @default(autoincrement()) @map("id")
  userId                BigInt?    @map("user_id")
  adminId               BigInt?    @map("admin_id")
  type                  WalletType @map("type")
  amount                Decimal    @default(0) @map("amount") @db.Decimal(15, 2)
  nonWithdrawableAmount Decimal    @default(0) @map("non_withdrawable_amount") @db.Decimal(15, 2) //locked winnings
  lockedAmount          Decimal    @default(0) @map("locked_amount") @db.Decimal(15, 2)
  exposureAmount        Decimal    @default(0) @map("exposure_amount") @db.Decimal(15, 2)
  creditAmount          Decimal    @default(0) @map("credit_amount") @db.Decimal(15, 2)
  version               Int        @default(0) @map("version")
  currencyId            Int        @map("currency_id")
  createdAt             DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  user               User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin              Admin?               @relation(fields: [adminId], references: [id], onDelete: Cascade)
  currency           Currency             @relation(fields: [currencyId], references: [id])
  walletTransactions WalletTransactions[]
  userWalletstats    UserWalletStat[]

  @@unique([userId, type])
  @@map("wallets")
}

model WalletTransactions {
  id                  BigInt                   @id @default(autoincrement()) @map("id")
  walletId            BigInt                   @map("wallet_id")
  amount              Decimal                  @map("amount") @db.Decimal(15, 2)
  availableBalance    Decimal                  @map("available_balance") @db.Decimal(15, 2)
  type                WalletTransactionType    @map("type")
  entityId            String?                  @map("entity_id")
  context             WalletTransactionContext @map("context")
  meta                Json?                    @map("meta")
  narration           String?                  @map("narration")
  nonce               BigInt                   @map("nonce")
  status              WalletTransactionStatus  @default(Confirmed) @map("status")
  remark              String?                  @map("remark")
  timestamp           DateTime                 @map("timestamp") @db.Timestamptz
  isCommissionSettled Boolean                  @default(false) @map("is_commission_settled")
  currencyId          Int                      @map("currency_id")
  fromAccount         String?                  @map("from_account")
  toAccount           String?                  @map("to_account")

  // process bonus for ctx deposit only
  isBonusProcessed Boolean @default(false) @map("is_bonus_processed")
  isWinningLocked  Boolean @default(false) @map("is_winning_locked")

  wallet   Wallet   @relation(fields: [walletId], references: [id])
  currency Currency @relation(fields: [currencyId], references: [id])

  @@unique([walletId, nonce])
  @@index([entityId, context])
  @@map("wallet_transactions")
}

model Currency {
  id             Int      @id @default(autoincrement()) @map("id")
  name           String   @map("name")
  code           String   @unique @map("code")
  symbol         String?  @map("symbol")
  conversionRate Decimal  @default(1) @map("conversion_rate") @db.Decimal(15, 6)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  Wallet             Wallet[]
  WalletTransactions WalletTransactions[]

  @@map("currency")
}

model Role {
  id          Int      @id @default(autoincrement()) @map("id")
  name        String   @unique @map("name")
  description String?  @map("description")
  level       Int      @map("level") // 👈 new column
  isEditable  Boolean  @default(true) @map("is_editable")
  updatedBy   BigInt?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  rolePrivileges RolePrivilege[] @relation("RoleToRolePrivileges")
  user           User[]          @relation("RoleToUser")
  Admin          Admin[]         @relation("RoleToAdmin")

  @@map("role")
}

model Privilege {
  id          Int      @id @default(autoincrement()) @map("id")
  permissions String   @unique @map("permissions")
  access      Json     @map("access")
  description String?  @map("description")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  rolePrivileges RolePrivilege[] @relation("PrivilegeToRolePrivileges")

  @@map("privilege")
}

model RolePrivilege {
  roleId        Int      @map("role_id")
  privilegeId   Int      @map("privilege_id")
  updatedAccess Json?    @map("updated_access")
  updatedBy     BigInt?  @map("updated_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  role      Role      @relation("RoleToRolePrivileges", fields: [roleId], references: [id])
  privilege Privilege @relation("PrivilegeToRolePrivileges", fields: [privilegeId], references: [id])

  @@unique([roleId, privilegeId])
  @@map("role_privilege")
}

model Provider {
  id           Int          @id @default(autoincrement()) @map("id")
  name         String       @map("name")
  providerType ProviderType @map("provider_type")
  settings     Json?        @map("settings")
  externalId   String?      @map("external_id")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  gameTypes   GameType[]
  casinoGames CasinoGame[]
  Competition Competition[]
  Event       Event[]

  @@unique([name, providerType])
  @@map("providers")
}

