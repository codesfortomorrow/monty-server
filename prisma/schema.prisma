enum ContactType {
  Whatsapp @map("whatsapp")
  Telegram @map("telegram")
  imo      @map("imo")
}

enum ExportType {
  casinoRoundHistory       @map("casino_rount_histry")
  casinoGame               @map("casino_game")
  userTransaction          @map("user_transaction")
  depositWithdraw          @map("deposit_withdraw")
  betReports               @map("bet_reports")
  casinoBetReports         @map("casino_Bet_reports")
  casinoDownlineProfitLoss @map("casino_downline_profit_loss")
  casinoPlayerProfitLoss   @map("casino_player_profit_loss")
  playerProfitLoss         @map("player_profit_loss")
  eventProfitLoss          @map("event_profit_loss")
  downlineProfitLoss       @map("downline_profit_loss")
  activity                 @map("activity")
  depositReport            @map("deposit_report")
  withdrawReport           @map("withdraw_report")
  loginReport              @map("login_report")
  signupReport             @map("signup_report")
  activeUsersReport        @map("active_users_report")
  idleUsersReport          @map("idle_users_report")
  subUsersReport           @map("sub_users_report")
  affiliateList            @map("affiliate_list")
  affiliateCommission      @map("affiliate_commission")
  bonusStatement           @map("bonus_statement")
  transaction              @map("transaction")
  gameTransaction          @map("game_transaction")

  @@map("export_type")
